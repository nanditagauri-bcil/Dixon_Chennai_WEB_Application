    <style>
        .navbar-nav > .user-menu > .dropdown-menu > li.user-header {
            height: auto;
        }

        .navbar-custom-menu > .navbar-nav > li > .dropdown-menu {
            position: absolute;
            right: 0;
            left: auto;
            box-shadow: -7px 7px 20px 2px #949494;
        }

        .modal-content {
            display: table;
            overflow-y: auto;
            overflow-x: auto;
            width: auto;
            position: fixed;
            top: calc(50% - 25px);
            padding-bottom: 20%;
            left: calc(-53% - 50px);
            right: calc(-53% - 50px);
            display: inline-block;
            grid-flow: columns;
        }

        .menu-link.active {
            background-color: darkcyan;
            color: white;
        }
    </style>
