        $(function () {
            //Initialize Select2 Elements
            $('.select2').select2()

            $(".select2multiple").select2({
                multiple: true,
            });
            //Datemask dd/mm/yyyy
            $('#datemask').inputmask('dd/mm/yyyy', { 'placeholder': 'dd/mm/yyyy' })
            //Datemask2 mm/dd/yyyy
            $('#datemask2').inputmask('mm/dd/yyyy', { 'placeholder': 'mm/dd/yyyy' })

            $('#datemask3').inputmask('yyyy-mm-dd', { 'placeholder': 'yyyy-mm-dd' })
            //Money Euro
            $('[data-mask]').inputmask()
            //Date range picker

            //Date picker
            $('#datepicker').datepicker({
                autoclose: true
            })

            //iCheck for checkbox and radio inputs
            $('input[type="checkbox"].minimal, input[type="radio"].minimal').iCheck({
                checkboxClass: 'icheckbox_minimal-blue',
                radioClass: 'iradio_minimal-blue'
            })
            //Red color scheme for iCheck
            $('input[type="checkbox"].minimal-red, input[type="radio"].minimal-red').iCheck({
                checkboxClass: 'icheckbox_minimal-red',
                radioClass: 'iradio_minimal-red'
            })
            //Flat red color scheme for iCheck
            $('input[type="checkbox"].flat-red, input[type="radio"].flat-red').iCheck({
                checkboxClass: 'icheckbox_flat-green',
                radioClass: 'iradio_flat-green'
            })
        })
    </script>
    <script>
        function isNumberKey(evt) {
            var charCode = (evt.which) ? evt.which : evt.keyCode;
            if (charCode > 31 && (charCode < 48 || charCode > 57))
                return false;
            return true;
        }
    </script>

    <script>
        //JS for filtering sidenav menu
        const replaceFormat = /[^a-zA-Z0-9]/g; // Remove any dots, slashes and whitespaces
        const emptyString = '';
        function filterMenu(event) {

            const searchString = event.value.replace(replaceFormat, emptyString).toLowerCase();
            const menuItems = $(".treeview-menu > li > a");

            $.each(menuItems, (index, menuItem) => {
                const menuItemText = $(menuItem).text().replace(replaceFormat, emptyString).toLowerCase();
                const parentMenu = $(menuItem).closest('.treeview');

                if (menuItemText.includes(searchString)) {
                    $(menuItem).show();
                    $(parentMenu).show();
                } else {
                    $(menuItem).hide();
                    $(parentMenu).hide();
                }
            });
        }

        //Highlight Sidenav Menu Link
        $(function () {
            const currentUrl = window.location.pathname.replace(replaceFormat, emptyString).toLowerCase();
            const urlParams = window.location.search?.replace(replaceFormat, emptyString).toLowerCase();
            const resultUrl = currentUrl.concat(urlParams);

            $('.menu-link').each(function () {
                const menuHref = $(this).attr('href').replace(replaceFormat, emptyString).toLowerCase();
                const parentMenu = $(this).closest('.treeview').children('a[href="javascript:void(0)"]');

                if (resultUrl.includes(menuHref)) {
                    $(this).addClass('active');
                    $(parentMenu).css('background-color', 'darkblue');
                } else {
                    $(this).removeClass('active');
                }
            });
        });
    </script>
</body>
