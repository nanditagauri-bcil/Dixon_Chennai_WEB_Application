    <script>
        //$(document).ready(function () {
        //    $(".select2").select2();

        //    $('.select2').each(function () {
        //        // Check if there's at least one non-null and non-empty option
        //        if ($(this).find('option').filter(function () {
        //            return this.value !== '' && this.value !== null;
        //        }).length > 0) {
